{
  "extends": "./tsconfig.base.flags.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "lib": ["esnext"],
    "emitDecoratorMetadata": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    //"noUncheckedIndexedAccess": true, // OMG NO !!
    "baseUrl": ".",
    "paths": {
      "@sh3pherd/shared-types": ["./packages/shared-types/src"],
      "@sh3pherd/storage": ["./packages/storage/src"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-types",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__"
  ],
  // for tsc -b
  "references": [
    { "path": "packages/shared-types" },
    { "path": "packages/storage" }
  ]
}

