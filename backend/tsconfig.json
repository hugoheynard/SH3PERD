{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@utils/*": ["utils/*"]
    },
    "types": ["node", "express", "jest"],
    "strict": true,
    "noImplicitAny": true,
    "lib": ["esnext"],
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/tests/**"
  ],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}