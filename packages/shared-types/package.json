{
  "name": "@sh3pherd/shared-types",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "dev:watch": "concurrently \"tsc -b tsconfig.json --watch\" \"tsc-alias --watch\"",
    "test": "jest",
    "clean": "find . \\( -type d -name dist -o -name .turbo -o -name .cache \\) -exec rm -rf {} + && find . -type f -name '*.tsbuildinfo' -delete"
  }
}