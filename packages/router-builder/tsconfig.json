{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declarationDir": "dist/types",
    "composite": true,
    "declaration": true,
    "baseUrl": "."
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "dist/types",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**"
  ],
  "references": [
    { "path": "../shared-types" },
    { "path": "../shared-utils" }
  ]
}