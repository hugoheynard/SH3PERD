{
  "extends": "../tsconfig.lib.json",
  "compilerOptions": {
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "exclude": ["../src/test.ts", "../**/*.spec.ts"],
  "include": ["../src/**/*", "./*.ts"]
}
