{
  "name": "@sh3pherd/ui-angular",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/public-api.ts",
      "types": "./src/public-api.ts"
    },
    "./styles": {
      "sass": "./styles/index.scss"
    }
  },
  "scripts": {
    "build": "ng build ui-angular",
    "storybook": "ng run ui-angular:storybook",
    "build-storybook": "ng run ui-angular:build-storybook",
    "test": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --config=jest.config.ts"
  },
  "peerDependencies": {
    "@angular/cli": "^21.2.5",
    "@angular/common": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "ngPackage": {
    "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
    "lib": {
      "entryFile": "src/public-api.ts",
      "assets": [
        "src/styles/**/*.scss"
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.3",
    "@angular/language-service": "^21.2.6",
    "@storybook/addon-actions": "^8.6.14",
    "@storybook/addon-controls": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/angular": "^8.6.14",
    "@storybook/builder-webpack5": "8.6.14",
    "@storybook/cli": "^9.0.12",
    "@storybook/types": "^8.6.14",
    "@types/jest": "^29.5.14",
    "css-loader": "^7.1.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.0",
    "jest-transform-stub": "^2.0.0",
    "ng-inline": "^0.0.2",
    "ng-packagr": "^19.2.2",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "storybook": "^8.6.14",
    "style-loader": "^4.0.0",
    "to-string-loader": "^1.2.0",
    "ts-jest": "^29.4.0",
    "webpack": "^5.99.9"
  }
}
