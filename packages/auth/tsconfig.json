{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@sh3pherd/shared-types": ["../shared-types/src/index"],
      "@sh3pherd/shared-utils": ["../shared-utils/src/index"],
      "@sh3pherd/token-manager": ["../token-manager/src/index"],
      "@sh3pherd/route-builder": ["../route-builder/src/index"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../shared-types" },
    { "path": "../shared-utils" },
    { "path":  "../token-manager"},
    { "path": "../router-builder"}
  ]
}