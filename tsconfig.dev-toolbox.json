{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "dev-toolbox",
    "outDir": "dist-dev-toolbox",
    "module": "NodeNext",
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": false,
    "strict": true
  },
  "include": ["dev-toolbox/scripts"]
}