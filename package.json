{
  "name": "sh3pherd-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "create:package": "tsx dev-toolbox/scripts/create-package.ts",
    "updatePackagesRefs": "tsx dev-toolbox/scripts/update-packageRefs.ts",
    "lint:imports": "tsx dev-toolbox/scripts/scan-cross-package-imports.ts",
    "clean": "rimraf packages/*/dist",
    "build": "npm run updatePackagesRefs && tsc -b tsconfig.build.json -w --verbose ",
    "dev": "concurrently \"tsc --watch -b tsconfig.build.json\" \"tsc-alias -p tsconfig.build.json --watch\" \"nodemon --watch 'packages/bootstrap/dist/**/*.js' --exec 'node --inspect=9229 packages/bootstrap/dist/main.js'\"",
    "dev:backend": "npm run dev --workspace=backend",
    "start:backend": "npm run start --workspace=backend",
    "test": "jest --workspaces"
  },
  "author": "Hugo Heynard",
  "license": "ISC",
  "peerDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "rimraf": "^5.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
