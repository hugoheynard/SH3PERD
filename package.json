{
  "name": "sh3pherd-monorepo",
  "version": "1.0.0",
  "author": "Hugo Heynard",
  "license": "ISC",
  "private": true,
  "packageManager": "npm@10.8.2",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "create:package": "tsx dev-toolbox/scripts/create-package.ts",
    "updatePackagesRefs": "tsx dev-toolbox/scripts/update-packageRefs.ts",
    "lint:imports": "tsx dev-toolbox/scripts/scan-cross-package-imports.ts",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo",
    "check:dev-watch": "tsx dev-toolbox/scripts/find-missing-devWatch.ts",
    "fix:js-extensions": "tsx dev-toolbox/scripts/fix-js-extensions.ts",
    "build": "turbo run build",
    "dev:watch": "turbo run dev:watch",
    "test": "jest --workspaces"
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "addJsExtension": true
  },
  "peerDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "rimraf": "^5.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "rxjs": "^7.8.2"
  }
}
