{
  "name": "sh3pherd-monorepo",
  "version": "1.0.0",
  "author": "Hugo Heynard",
  "license": "ISC",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev:backend": "turbo run start --filter=@sh3pherd/backend",
    "dev:webapp": "turbo run start --filter=@sh3pherd/frontend-webapp",
    "dev:all": "pnpm run dev:watch & pnpm run dev:backend",
    "setup:hooks": "git config core.hooksPath .githooks",
    "create:package": "tsx dev-toolbox/scripts/create-package.ts",
    "updatePackagesRefs": "tsx dev-toolbox/scripts/update-packageRefs.ts",
    "lint:imports": "tsx dev-toolbox/scripts/scan-cross-package-imports.ts",
    "build": "turbo run build",
    "predev:watch": "pnpm run setup:hooks",
    "dev:watch": "turbo run dev:watch --filter=@sh3pherd/backend --filter=@sh3pherd/shared-types --log-order=stream --log-prefix=none --output-logs=full",
    "test": "jest --workspaces",
    "clean": "turbo run clean"
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "addJsExtension": true
  },
  "peerDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0"
  },
  "pnpm": {
    "overrides": {
      "@angular/forms": "^21.2.6"
    }
  },
  "devDependencies": {
    "@angular/cli": "^21.2.5",
    "@eslint/js": "^9.28.0",
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.4.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.5.5",
    "lint-staged": "^16.1.2",
    "madge": "^8.0.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsc-esm-fix": "^3.1.2",
    "tsc-watch": "^6.2.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.34.0",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.17.0",
    "rxjs": "^7.8.2",
    "zod": "^3.25.67"
  }
}
