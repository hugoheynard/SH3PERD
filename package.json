{
  "name": "SH3PHERD",
  "version": "1.0.0",
  "description": "",
  "main": "script.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf backend/dist",
    "dev": "concurrently \"tsc --watch -p backend/tsconfig.json 2>&1\" \"tsc-alias -p backend/tsconfig.json --watch\" \"nodemon --watch 'backend/dist/**/*.js' --exec 'node --inspect=9229 backend/dist/app.js'\"",
    "build": "echo 'Étape 1: Compilation...' ; tsc -p backend/tsconfig.json ; echo 'Étape 2: Résolution des alias...' && tsc-alias -p backend/tsconfig.json ;",
    "start": "nodemon node backend/dist/app.js",
    "test:backend": "NODE_OPTIONS='--experimental-vm-modules' jest --config=backend/jest.backend.config.js",
    "test:frontend": "NODE_OPTIONS='--experimental-vm-modules' jest --config=frontend/jest.frontend.config.js"
  },
  "author": "Hugo Heynard",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsdom": "^25.0.0",
    "mongodb": "^6.10.0",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-class-properties": "^7.25.4",
    "@babel/plugin-transform-private-methods": "^7.25.4",
    "@babel/preset-env": "^7.25.4",
    "@jest/globals": "^29.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.9.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.6.3"
  }
}
