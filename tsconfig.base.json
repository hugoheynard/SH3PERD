{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node", "jest"],
    "lib": ["esnext"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "declarationMap": true,
    "allowJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "emitDeclarationOnly": false,
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@sh3pherd/calendar": ["packages/calendar/src/index.ts"],
      "@sh3pherd/shared-types": ["packages/shared-types/src/index.ts"],
        "@sh3pherd/playlist": ["packages/playlist/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "dist-types",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__"
  ],
  "references": [
    { "path": "../shared-types"},
    { "path": "../shared-utils"},
  ]
}

