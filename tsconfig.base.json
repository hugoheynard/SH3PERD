{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "types": ["node", "jest"],
    "lib": ["esnext"],
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": false, //true
    "noUnusedParameters": false, //true
    "noFallthroughCasesInSwitch": true,
    "declarationMap": true,
    "allowJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": false, //added
    "emitDeclarationOnly": false, //added
    "baseUrl": ".",
    "paths": {
      "@sh3pherd/*": ["packages/*/src/index.ts"],
      "@sh3pherd/shared-types/*": ["packages/shared-types/src/*"],
      "@sh3pherd/shared-utils/*": ["packages/shared-utils/src/*"]
    }
  },
}

